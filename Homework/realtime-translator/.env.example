# 복사해서 .env 로 만드세요:  cp .env.example .env
# Groq 무료 API 키 — https://console.groq.com/keys 에서 무료 발급
GROQ_API_KEY=your-groq-api-key-here

# 답변 추천(품질 우선) / 번역(속도 우선) 모델
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# faster-whisper 모델 크기: tiny / base / small  (클수록 정확·느림)
WHISPER_MODEL=base
