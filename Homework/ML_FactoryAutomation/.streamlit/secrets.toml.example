# Streamlit Cloud 배포 시 이 파일을 참고하여 Secrets 설정
# share.streamlit.io → App settings → Secrets 메뉴에 아래 내용 입력

GEMINI_API_KEY = "your-gemini-api-key-here"

# Supabase PostgreSQL 연결 URL (영구 저장용)
# Supabase → Project Settings → Database → Connection string (URI) 복사
# Session mode(포트 5432): 일반 연결 / Transaction mode(포트 6543): 연결 풀링
DATABASE_URL = "postgresql://postgres:[password]@[host]:5432/postgres"
